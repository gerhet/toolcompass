      tool_travel: "Budget Voyage",
      tool_travel_desc: "Estimations de vacances.",
      footer_copy: "ToolCompass.org &copy; 2026 — Outils Professionnels en Ligne"
    }
  };

  // ============================================
  // SET LANGUAGE
  // ============================================
  function setLang(lang) {
    const t = translations[lang];
    if (!t) return;

    // HTML lang attribute
    document.documentElement.lang = lang;
    
    // Save preference
    localStorage.setItem('preferredLanguage', lang);

    // Update UI buttons
    document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('active'));
    event.target.classList.add('active');

    // Meta tags for SEO (dynamic update)
    document.getElementById('meta-title').textContent = t.meta_title;
    document.getElementById('meta-description').textContent = t.meta_desc;
    const schemaScript = JSON.parse(document.getElementById('schema-json').textContent);
    schemaScript.description = t.meta_schema_desc;
    document.getElementById('schema-json').textContent = JSON.stringify(schemaScript);

    // Hero & Header
    document.getElementById('trans-live').textContent = `31 ${t.live}`; // "31 tools live" vs "31 outils actifs"
    document.getElementById('trans-hero-badge').textContent = t.hero_badge;
    document.getElementById('trans-hero-title1').textContent = t.hero_title1;
    document.getElementById('trans-hero-title2').textContent = t.hero_title2;
    document.getElementById('trans-hero-sub').textContent = t.hero_sub;
    document.getElementById('trans-stat1').textContent = t.stat1;
    document.getElementById('trans-stat2').textContent = t.stat2;
    document.getElementById('trans-scroll').textContent = t.scroll;
    document.getElementById('search').placeholder = t.search;

    // Categories
    const setCat = (id, text) => { if(document.getElementById(id)) document.getElementById(id).textContent = text; };
    setCat('trans-cat-finance', t.cat_finance);
    setCat('trans-cat-finance-sub', t.cat_finance_sub);
    setCat('trans-cat-finance-count', t.cat_finance_count);
    setCat('trans-cat-content', t.cat_content);
    setCat('trans-cat-content-sub', t.cat_content_sub);
    setCat('trans-cat-content-count', t.cat_content_count);
    setCat('trans-cat-tech', t.cat_tech);
    setCat('trans-cat-tech-sub', t.cat_tech_sub);
    setCat('trans-cat-tech-count', t.cat_tech_count);
    setCat('trans-cat-time', t.cat_time);
    setCat('trans-cat-time-sub', t.cat_time_sub);
    setCat('trans-cat-time-count', t.cat_time_count);
    setCat('trans-cat-health', t.cat_health);
    setCat('trans-cat-health-sub', t.cat_health_sub);
    setCat('trans-cat-health-count', t.cat_health_count);

    // Tool Names & Descriptions
    const tools = [
      {n:'badge-new', d:'badge_new'},
      {n:'tool-briefing', d:'tool_briefing', desc:'tool_briefing_desc'},
      {n:'tool-mortgage', d:'tool_mortgage', desc:'tool_mortgage_desc'},
      {n:'tool-hourly', d:'tool_hourly', desc:'tool_hourly_desc'},
      {n:'tool-vat', d:'tool_vat', desc:'tool_vat_desc'},
      {n:'tool-loan', d:'tool_loan', desc:'tool_loan_desc'},
      {n:'tool-tip', d:'tool_tip', desc:'tool_tip_desc'},
      {n:'tool-summary', d:'tool_summary', desc:'tool_summary_desc'},
      {n:'tool-counter', d:'tool_counter', desc:'tool_counter_desc'},
      {n:'tool-case', d:'tool_case', desc:'tool_case_desc'},
      {n:'tool-subject', d:'tool_subject', desc:'tool_subject_desc'},
      {n:'tool-linkedin', d:'tool_linkedin', desc:'tool_linkedin_desc'},
      {n:'tool-bio', d:'tool_bio', desc:'tool_bio_desc'},
      {n:'tool-privacy', d:'tool_privacy', desc:'tool_privacy_desc'},
      {n:'tool-qr', d:'tool_qr', desc:'tool_qr_desc'},
      {n:'tool-json', d:'tool_json', desc:'tool_json_desc'},
      {n:'tool-base64', d:'tool_base64', desc:'tool_base64_desc'},
      {n:'tool-binary', d:'tool_binary', desc:'tool_binary_desc'},
      {n:'tool-color', d:'tool_color', desc:'tool_color_desc'},
      {n:'tool-password', d:'tool_password', desc:'tool_password_desc'},
      {n:'tool-pomo', d:'tool_pomo', desc:'tool_pomo_desc'},
      {n:'tool-stopwatch', d:'tool_stopwatch', desc:'tool_stopwatch_desc'},
      {n:'tool-workdays', d:'tool_workdays', desc:'tool_workdays_desc'},
      {n:'tool-year', d:'tool_year', desc:'tool_year_desc'},
      {n:'tool-world', d:'tool_world', desc:'tool_world_desc'},
      {n:'tool-countdown', d:'tool_countdown', desc:'tool_countdown_desc'},
      {n:'tool-bmi', d:'tool_bmi', desc:'tool_bmi_desc'},
      {n:'tool-age', d:'tool_age', desc:'tool_age_desc'},
      {n:'tool-percentage', d:'tool_percentage', desc:'tool_percentage_desc'},
      {n:'tool-name', d:'tool_name', desc:'tool_name_desc'},
      {n:'tool-co2', d:'tool_co2', desc:'tool_co2_desc'},
      {n:'tool-travel', d:'tool_travel', desc:'tool_travel_desc'},
    ];
    tools.forEach(k => {
      const elN = document.getElementById(`trans-${k.n}`);
      const elD = document.getElementById(`trans-${k.n}-desc`);
      if (elN) elN.textContent = t[k.d];
      if (elD && k.desc) elD.textContent = t[k.desc];
    });

    // Footer
    document.getElementById('trans-footer-copy').textContent = t.footer_copy;
  }

  // ============================================
  // SEARCH & REVEAL (KEEP EXISTING LOGIC)
  // ============================================
  const searchEl = document.getElementById('search');
  searchEl.addEventListener('input', () => {
    const q = searchEl.value.toLowerCase().trim();
    document.querySelectorAll('.cat-block').forEach(block => {
      const cards = block.querySelectorAll('.tool-card');
      let visible = 0;
      cards.forEach(card => {
        const match = !q || card.dataset.name.includes(q);
        card.classList.toggle('hidden', !match);
        if (match) visible++;
      });
      block.classList.toggle('all-hidden', visible === 0);
    });
  });

  const obs = new IntersectionObserver((entries) => {
    entries.forEach((e, i) => {
      if (e.isIntersecting) {
        setTimeout(() => e.target.classList.add('visible'), i * 80);
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.06 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

  // ============================================
  // INIT: Load preferred language on startup
  // ============================================
  document.addEventListener('DOMContentLoaded', () => {
    const savedLang = localStorage.getItem('preferredLanguage') || 'en'; // Default English
    // Force set the button state and apply lang
    const btn = document.querySelector(`.lang-btn[onclick="setLang('${savedLang}')"]`);
    if(btn) {
      btn.classList.add('active');
      setLang(savedLang);
    }
  });
</script>

